* Measure JNW_EXA
.control

load {cicname}.raw

echo "MEAS_START"

let ibn = -i(v0)        
let r_diff = v(xdut.net1) - v(xdut.net2)

meas tran r_drop find r_diff at=5n
meas tran x1_drain find xdut.net1 at=5n
meas tran x2_drain find xdut.net2 at=5n
meas tran ibns_out find ibn at=5n

echo "MEAS_END"
.endc
